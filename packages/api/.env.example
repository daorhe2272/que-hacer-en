# =============================================================================
# API environment variables — copy to .env and fill in real values.
# Real .env files are gitignored and must never be committed.
# =============================================================================

# --- Server ---------------------------------------------------------------
# Express listen port. In production (Cloud Run) this is API_PORT=4001;
# nginx proxies /api/* to it on localhost.
API_PORT=4001
# Comma-separated allowlist of CORS origins. Empty = allow all (dev only).
CORS_ORIGINS=http://localhost:4000
NODE_ENV=development

# --- Database -------------------------------------------------------------
# PostgreSQL connection string. On Supabase use the Session Pooler (port 6543).
DATABASE_URL=postgresql://user:password@host:6543/postgres

# --- Supabase auth (shared with web) --------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- On-demand revalidation (must match the web package) ------------------
NEXT_PUBLIC_WEB_URL=http://localhost:4000
REVALIDATE_SECRET=your-shared-secret

# --- AI moderation (Google GenAI) -----------------------------------------
GOOGLE_API_KEY=your-google-genai-key

# --- Puppeteer / Chromium -------------------------------------------------
# The API uses puppeteer-core, which does NOT bundle a browser — it launches
# whatever Chromium binary PUPPETEER_EXECUTABLE_PATH points to.
#
# Production (Docker/Cloud Run): set by the Dockerfile to Alpine's chromium:
#   PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
#
# Development: point this at your locally installed Chrome/Chromium, e.g.
#   Windows: PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
#   macOS:   PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Linux:   PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
# If unset, the data-sources / scraping route cannot launch a browser.
PUPPETEER_EXECUTABLE_PATH=